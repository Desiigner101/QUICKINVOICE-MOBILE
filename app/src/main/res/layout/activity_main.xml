<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#ffffff"
    android:fitsSystemWindows="true">

    <!-- NAVBAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="#ffffff"
        android:paddingStart="24dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚡ QuickInvoice"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#0D6EFD"
            android:letterSpacing="0.02"/>

        <ImageButton
            android:id="@+id/btnHamburger"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_menu"
            android:backgroundTint="@android:color/transparent"
            android:tint="#374151"
            android:padding="10dp"
            android:contentDescription="Menu"/>

    </LinearLayout>

    <!-- Navbar shadow line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F3F4F6"/>

    <!-- DRAWER MENU -->
    <LinearLayout
        android:id="@+id/drawerMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#ffffff"
        android:elevation="12dp"
        android:visibility="gone">

        <!-- Home item -->
        <LinearLayout
            android:id="@+id/menuHome"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="15sp"
                android:textColor="#111827"
                android:fontFamily="sans-serif-medium"/>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F3F4F6"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"/>

        <!-- Login item -->
        <LinearLayout
            android:id="@+id/menuLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:background="?attr/selectableItemBackground">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Login / Sign Up"
                android:textSize="15sp"
                android:textColor="#0D6EFD"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textSize="16sp"
                android:textColor="#0D6EFD"/>

        </LinearLayout>

        <!-- Bottom border -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F3F4F6"/>

    </LinearLayout>

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HERO SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#0D6EFD"
                android:orientation="vertical"
                android:padding="32dp"
                android:gravity="center"
                android:minHeight="400dp">


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Effortless Invoicing.\nProfessional Results."
                    android:textColor="#ffffff"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stop wrestling with spreadsheets. Quick Invoice helps you create and send beautiful invoices in minutes, so you get paid faster."
                    android:textColor="#CCffffff"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_marginBottom="32dp"/>

                <Button
                    android:id="@+id/btnGetStarted"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Generate Your First Invoice"
                    android:backgroundTint="#FFC107"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnLearnMore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Learn More"
                    android:backgroundTint="@android:color/transparent"
                    android:textColor="#ffffff"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"/>

            </LinearLayout>

            <!-- HOW IT WORKS SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#F8F9FA"
                android:padding="32dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Get Started in 4 Simple Steps"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#0D6EFD"
                    android:gravity="center"
                    android:layout_marginBottom="24dp"/>

                <!-- Step 1 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:text="1"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#ffffff"
                            android:background="@drawable/circle_blue"
                            android:gravity="center"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Enter Details"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quickly fill in your client's information, item descriptions, quantities, and prices."
                            android:textSize="14sp"
                            android:textColor="#6C757D"
                            android:gravity="center"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Step 2 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:text="2"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#ffffff"
                            android:background="@drawable/circle_green"
                            android:gravity="center"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Choose Template"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Browse our gallery of professionally designed templates. Pick one that matches your brand."
                            android:textSize="14sp"
                            android:textColor="#6C757D"
                            android:gravity="center"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Step 3 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:text="3"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:background="@drawable/circle_yellow"
                            android:gravity="center"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Preview Invoice"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="See exactly how your invoice will look before sending it. Make any last-minute adjustments."
                            android:textSize="14sp"
                            android:textColor="#6C757D"
                            android:gravity="center"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Step 4 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:text="4"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#ffffff"
                            android:background="@drawable/circle_cyan"
                            android:gravity="center"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Download and Save"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#000000"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Download your invoice as a PDF, send it via email, or save it for your records."
                            android:textSize="14sp"
                            android:textColor="#6C757D"
                            android:gravity="center"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- FEATURES SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#ffffff"
                android:padding="32dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Why Choose Quick Invoice?"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#0D6EFD"
                    android:gravity="center"
                    android:layout_marginBottom="32dp"/>

                <!-- Feature 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="32dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/landing1"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Easy to Fill Invoice Details"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#0D6EFD"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Creating professional invoices has never been easier. Our intuitive interface guides you through every step."
                        android:textSize="14sp"
                        android:textColor="#6C757D"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓  Curated list of templates from gallery."
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#6C757D"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓  Add your logo and invoice details."
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#6C757D"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓  Tailor fields to your needs."
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#6C757D"/>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="32dp"/>

                <!-- Feature 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="32dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/landing2"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Beautiful Dashboard"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#0D6EFD"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stay organized with our elegant dashboard that puts all your invoices at your fingertips."
                        android:textSize="14sp"
                        android:textColor="#6C757D"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓  View the previous invoices."
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#6C757D"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓  Your saved invoices with thumbnail."
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#6C757D"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓  Reuse and track invoices."
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#6C757D"/>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="32dp"/>

                <!-- Feature 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="32dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/landing3"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Invoice Preview with Action Buttons"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#0D6EFD"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See exactly what your clients will receive before you hit send."
                        android:textSize="14sp"
                        android:textColor="#6C757D"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓  Live preview."
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#6C757D"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓  Switch between multiple invoices."
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#6C757D"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓  One click to Save, Download and Delete."
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#6C757D"/>
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="32dp"/>

                <!-- Feature 4 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/landing4"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Send Invoices Instantly"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#0D6EFD"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Get paid faster with instant invoice delivery."
                        android:textSize="14sp"
                        android:textColor="#6C757D"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓  Send invoices without leaving the app."
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#6C757D"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓  One click to send invoices."
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#6C757D"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓  Send unlimited invoices."
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#6C757D"/>
                </LinearLayout>

            </LinearLayout>

            <!-- CTA SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#0D6EFD"
                android:padding="32dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ready to Streamline Your Invoicing?"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Join thousands of freelancers and small businesses who trust Quick Invoice. Start creating professional invoices today!"
                    android:textSize="14sp"
                    android:textColor="#CCffffff"
                    android:gravity="center"
                    android:layout_marginBottom="24dp"/>

                <Button
                    android:id="@+id/btnStartNow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Start Generating Invoices Now"
                    android:backgroundTint="#FFC107"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="This will lead to the invoice generation interface"
                    android:textSize="12sp"
                    android:textColor="#99ffffff"/>

            </LinearLayout>

            <!-- FOOTER SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#212529"
                android:padding="32dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡ QuickInvoice"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="© 2025 Quick Invoice. All Rights Reserved."
                    android:textSize="12sp"
                    android:textColor="#6C757D"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Crafted with ♥ for freelancers and small businesses."
                    android:textSize="12sp"
                    android:textColor="#6C757D"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnInstagram"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="IG"
                        android:textColor="#ffffff"
                        android:backgroundTint="@android:color/transparent"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnFacebook"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FB"
                        android:textColor="#ffffff"
                        android:backgroundTint="@android:color/transparent"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnLinkedin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="IN"
                        android:textColor="#ffffff"
                        android:backgroundTint="@android:color/transparent"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>