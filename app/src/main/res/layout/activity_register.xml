<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Logo + Brand -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡"
                android:textSize="48sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QuickInvoice"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#0D6EFD"
                android:letterSpacing="0.02"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create your account"
                android:textSize="16sp"
                android:textColor="#374151"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome! Please fill in the details to get started."
                android:textSize="13sp"
                android:textColor="#9CA3AF"
                android:gravity="center"/>

        </LinearLayout>

        <!-- Card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Social Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <androidx.cardview.widget.CardView
                        xmlns:app="http://schemas.android.com/apk/res-auto"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="1dp">
                        <Button
                            android:id="@+id/btnFacebook"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="Facebook"
                            android:textSize="11sp"
                            android:textColor="#374151"
                            android:backgroundTint="#ffffff"
                            style="@style/Widget.AppCompat.Button.Borderless"/>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        xmlns:app="http://schemas.android.com/apk/res-auto"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="1dp">
                        <Button
                            android:id="@+id/btnGithub"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="GitHub"
                            android:textSize="11sp"
                            android:textColor="#374151"
                            android:backgroundTint="#ffffff"
                            style="@style/Widget.AppCompat.Button.Borderless"/>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        xmlns:app="http://schemas.android.com/apk/res-auto"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="1dp">
                        <Button
                            android:id="@+id/btnGoogle"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="Google"
                            android:textSize="11sp"
                            android:textColor="#374151"
                            android:backgroundTint="#ffffff"
                            style="@style/Widget.AppCompat.Button.Borderless"/>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <!-- OR Divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E5E7EB"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  or continue with email  "
                        android:textColor="#9CA3AF"
                        android:textSize="11sp"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#E5E7EB"/>

                </LinearLayout>

                <!-- First Name + Last Name -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="First name"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#374151"
                            android:layout_marginBottom="6dp"/>

                        <EditText
                            android:id="@+id/etFirstName"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:hint="John"
                            android:inputType="textPersonName"
                            android:background="@drawable/input_background"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:textSize="14sp"
                            android:textColor="#111827"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Last name"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#374151"
                            android:layout_marginBottom="6dp"/>

                        <EditText
                            android:id="@+id/etLastName"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:hint="Doe"
                            android:inputType="textPersonName"
                            android:background="@drawable/input_background"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:textSize="14sp"
                            android:textColor="#111827"
                            />

                    </LinearLayout>

                </LinearLayout>

                <!-- Email -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Email address"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="you@example.com"
                    android:inputType="textEmailAddress"
                    android:background="@drawable/input_background"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="14sp"
                    android:textColor="#111827"
                    android:layout_marginBottom="16dp"/>

                <!-- Password -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Min. 8 characters"
                    android:inputType="textPassword"
                    android:background="@drawable/input_background"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="14sp"
                    android:textColor="#111827"
                    android:layout_marginBottom="16dp"/>

                <!-- Confirm Password -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Confirm password"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Re-enter your password"
                    android:inputType="textPassword"
                    android:background="@drawable/input_background"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="14sp"
                    android:textColor="#111827"
                    android:layout_marginBottom="24dp"/>

                <!-- Progress Bar -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp"/>

                <!-- Register Button -->
                <Button
                    android:id="@+id/btnContinue"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Create Account →"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#ffffff"
                    android:backgroundTint="#0D6EFD"
                    android:layout_marginBottom="16dp"/>

                <!-- Sign In Link -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Already have an account? "
                        android:textSize="13sp"
                        android:textColor="#6B7280"/>

                    <TextView
                        android:id="@+id/tvSignIn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sign in"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#0D6EFD"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Secured by -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒  Secured by QuickInvoice"
                android:textSize="12sp"
                android:textColor="#9CA3AF"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>