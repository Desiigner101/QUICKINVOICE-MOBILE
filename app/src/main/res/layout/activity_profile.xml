<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F9FAFB"
    android:fitsSystemWindows="true">

    <!-- NAVBAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="#ffffff"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:backgroundTint="@android:color/transparent"
            android:tint="#374151"
            android:contentDescription="Back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="My Profile"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:layout_marginStart="12dp"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F3F4F6"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Profile Photo Card -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <!-- Profile Photo -->
                    <FrameLayout
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:id="@+id/ivProfilePhoto"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:scaleType="centerCrop"
                            android:background="@drawable/circle_blue"/>

                        <TextView
                            android:id="@+id/tvProfileInitial"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:text="G"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:textColor="#ffffff"
                            android:gravity="center"
                            android:background="@drawable/circle_blue"/>

                        <!-- Camera overlay -->
                        <LinearLayout
                            android:id="@+id/btnChangePhoto"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="bottom|end"
                            android:background="@drawable/circle_blue"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📷"
                                android:textSize="14sp"/>

                        </LinearLayout>

                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gino Sarsonas"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#111827"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvProfileEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="email@example.com"
                        android:textSize="14sp"
                        android:textColor="#6B7280"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Edit Profile Card -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✏️ Edit Profile"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#111827"
                        android:layout_marginBottom="16dp"/>

                    <!-- First Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="First Name"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#374151"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etFirstName"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="First name"
                        android:background="@drawable/input_background"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textSize="14sp"
                        android:textColor="#111827"
                        android:inputType="textPersonName"
                        android:layout_marginBottom="12dp"/>

                    <!-- Last Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last Name"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#374151"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etLastName"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="Last name"
                        android:background="@drawable/input_background"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textSize="14sp"
                        android:textColor="#111827"
                        android:inputType="textPersonName"
                        android:layout_marginBottom="12dp"/>

                    <!-- Email (read only) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email Address"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#374151"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_background"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textSize="14sp"
                        android:textColor="#9CA3AF"
                        android:enabled="false"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email cannot be changed"
                        android:textSize="11sp"
                        android:textColor="#9CA3AF"
                        android:layout_marginBottom="16dp"/>

                    <!-- Save Profile Button -->
                    <Button
                        android:id="@+id/btnSaveProfile"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Save Changes"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#ffffff"
                        android:backgroundTint="#0D6EFD"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Change Password Card -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒 Change Password"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#111827"
                        android:layout_marginBottom="16dp"/>

                    <!-- New Password -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="New Password"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#374151"
                        android:layout_marginBottom="6dp"/>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginBottom="12dp">

                        <EditText
                            android:id="@+id/etNewPassword"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:hint="Enter new password"
                            android:inputType="textPassword"
                            android:background="@drawable/input_background"
                            android:paddingStart="16dp"
                            android:paddingEnd="52dp"
                            android:textSize="14sp"
                            android:textColor="#111827"/>

                        <ImageButton
                            android:id="@+id/btnToggleNewPassword"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="end|center_vertical"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_eye_off"
                            android:backgroundTint="@android:color/transparent"
                            android:tint="#9CA3AF"
                            android:contentDescription="Toggle password"/>

                    </FrameLayout>

                    <!-- Confirm Password -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Confirm New Password"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#374151"
                        android:layout_marginBottom="6dp"/>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginBottom="16dp">

                        <EditText
                            android:id="@+id/etConfirmPassword"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:hint="Confirm new password"
                            android:inputType="textPassword"
                            android:background="@drawable/input_background"
                            android:paddingStart="16dp"
                            android:paddingEnd="52dp"
                            android:textSize="14sp"
                            android:textColor="#111827"/>

                        <ImageButton
                            android:id="@+id/btnToggleConfirmPassword"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="end|center_vertical"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/ic_eye_off"
                            android:backgroundTint="@android:color/transparent"
                            android:tint="#9CA3AF"
                            android:contentDescription="Toggle confirm password"/>

                    </FrameLayout>

                    <Button
                        android:id="@+id/btnChangePassword"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Update Password"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#ffffff"
                        android:backgroundTint="#111827"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Danger Zone Card -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️ Danger Zone"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#EF4444"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Once you delete your account, there is no going back. All your invoices will be permanently deleted."
                        android:textSize="13sp"
                        android:textColor="#6B7280"
                        android:layout_marginBottom="16dp"/>

                    <Button
                        android:id="@+id/btnDeleteAccount"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Delete Account"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#ffffff"
                        android:backgroundTint="#EF4444"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Loading overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"/>

    </FrameLayout>

</LinearLayout>